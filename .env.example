# Copy to `.env` for local dev. Never commit real secrets.
#
# --- Vercel (Production / Preview) ---
# Vite bakes these in at *build* time. Your hosting must provide them when `vite build` runs.
#
# 1. Vercel → your project → Settings → Environment Variables
# 2. Add each variable with the EXACT name below (including VITE_ prefix).
# 3. Check "Production" and/or "Preview" so the build that deploys gets the values.
# 4. Save, then Deployments → Redeploy (or push a new commit).
#
# Common mistakes:
# - Using WEB3FORMS_ACCESS_KEY without the VITE_ prefix (will not appear in the app).
# - Setting variables only for "Development" in Vercel (local `vercel dev`) but not Production.
# - Forgetting to redeploy after changing env.

# Web3Forms — https://web3forms.com
VITE_WEB3FORMS_ACCESS_KEY=

# Contentful — Content Delivery API (Settings → API keys in your space)
# https://www.contentful.com/developers/docs/references/content-delivery-api/
VITE_CONTENTFUL_SPACE_ID=
VITE_CONTENTFUL_ACCESS_TOKEN=
# Optional global owner filter used by both experiences and portfolios.
# Defaults to `aichannode` if omitted.
VITE_CONTENTFUL_OWNER_NAME=aichannode
#
# Experiences (first CMS integration)
# - Content type ID: `experiences` — fields:
#     • name (Short text)
#       Use value that matches VITE_CONTENTFUL_OWNER_NAME
#     • items (Reference, many) → content type `experience`
# - Content type ID: `experience` — fields:
#     • company (Short text)
#     • role (Short text)
#     • startDate (Date & Time)
#     • endDate (Date & Time)
#     • content (Long text)
# Optional overrides:
# VITE_CONTENTFUL_EXPERIENCES_ENTRY_ID=<published parent entry id>  # if set, name query is skipped
# VITE_CONTENTFUL_CT_EXPERIENCES=experiences  # if your parent content type ID differs
#
# Portfolios (featured work)
# - Content type ID: `portfolios` — fields:
#     • name (Short text) — use value that matches VITE_CONTENTFUL_OWNER_NAME
#     • items (Reference, many) → content type `portfolio`
# - Content type ID: `portfolio` — fields:
#     • title (Short text)
#     • description (Long text)
#     • skills (Short text, list)
#     • link (Short text)
#     • thumbnail (Media, single file) — optional card cover; if empty, first `images` file is used
#     • images (Media, many files) — detail modal carousel (grid uses thumbnail when set, else first image)
# Optional overrides:
# VITE_CONTENTFUL_PORTFOLIOS_ENTRY_ID=<published parent entry id>  # if set, name query is skipped
# VITE_CONTENTFUL_CT_PORTFOLIOS=portfolios  # if your parent content type ID differs
#
# Social profile (footer + contact email / location)
# - Content type ID: `social` — fields (Short text unless noted):
#     • name — matches VITE_CONTENTFUL_OWNER_NAME (your nickname) for lookup
#     • fullname, role, phone, location, linkedin, email, github, facebook, twitter, website
# Optional overrides:
# VITE_CONTENTFUL_SOCIAL_ENTRY_ID=<published entry id>  # if set, name query is skipped
# VITE_CONTENTFUL_CT_SOCIAL=social  # if your content type ID differs
